/*!
 * \file asc_perf_benchmark.asc
 * \brief Ascend chip TFLOPS and memory bandwidth benchmark operator.
 *
 * Usage:
 *   ./asc_perf_benchmark compute M N K [warmup] [iter]
 *   ./asc_perf_benchmark bandwidth totalBytes [warmup] [iter]
 */

#include "acl/acl.h"
#include "kernel_operator.h"
#include "kernel_tiling/kernel_tiling.h"
#include "tiling/platform/platform_ascendc.h"
#include "tiling/tiling_api.h"
#define ASCENDC_CUBE_ONLY
#include "lib/matmul_intf.h"

#include <algorithm>
#include <chrono>
#include <cmath>
#include <cstdint>
#include <cstdio>
#include <cstdlib>
#include <cstring>
#include <string>

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

using namespace matmul;

constexpr uint32_t WARMUP_ITER_DEFAULT = 3;
constexpr uint32_t MEASURE_ITER_DEFAULT = 10;
constexpr uint32_t BANDWIDTH_CHUNK_SIZE = 8192; // elements per block (half), fits in UB

/*------------------------------------------------------------------------------
 * Compute benchmark: Matmul-based TFLOPS measurement
 *----------------------------------------------------------------------------*/

__global__ __cube__ void matmul_perf_custom(
    __gm__ uint8_t* a, __gm__ uint8_t* b, __gm__ uint8_t* c,
    __gm__ uint8_t* workspace, AscendC::tiling::TCubeTiling tiling)
{
    AscendC::TPipe pipe;

    AscendC::GlobalTensor<half> aGlobal;
    AscendC::GlobalTensor<half> bGlobal;
    AscendC::GlobalTensor<float> cGlobal;

    aGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ half*>(a), tiling.M * tiling.Ka);
    bGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ half*>(b), tiling.Kb * tiling.N);
    cGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(c), tiling.M * tiling.N);

    Matmul<
        MatmulType<AscendC::TPosition::GM, CubeFormat::ND, half>,
        MatmulType<AscendC::TPosition::GM, CubeFormat::ND, half>,
        MatmulType<AscendC::TPosition::GM, CubeFormat::ND, float>>
        mm;

    REGIST_MATMUL_OBJ(&pipe, GetSysWorkSpacePtr(), mm, &tiling);

    mm.SetOrgShape(tiling.M, tiling.N, tiling.Ka, tiling.Kb);
    mm.SetTensorA(aGlobal[GetBlockIdx() * tiling.singleCoreM * tiling.Ka], false);
    mm.SetTensorB(bGlobal[0], false);
    mm.IterateAll(cGlobal[GetBlockIdx() * tiling.singleCoreM * tiling.N]);
    mm.End();
}

AscendC::tiling::TCubeTiling GenerateMatmulTiling(
    platform_ascendc::PlatformAscendC* ascendcPlatform,
    int32_t M, int32_t N, int32_t K)
{
    AscendC::tiling::TCubeTiling tilingData{};
    matmul_tiling::MultiCoreMatmulTiling tilingApi(*ascendcPlatform);

    tilingApi.SetDim(ascendcPlatform->GetCoreNumAic());
    tilingApi.SetAType(
        matmul_tiling::TPosition::GM, matmul_tiling::CubeFormat::ND,
        matmul_tiling::DataType::DT_FLOAT16, false);
    tilingApi.SetBType(
        matmul_tiling::TPosition::GM, matmul_tiling::CubeFormat::ND,
        matmul_tiling::DataType::DT_FLOAT16, false);
    tilingApi.SetCType(
        matmul_tiling::TPosition::GM, matmul_tiling::CubeFormat::ND,
        matmul_tiling::DataType::DT_FLOAT);
    tilingApi.SetOrgShape(M, N, K);
    tilingApi.SetShape(M, N, K);
    tilingApi.EnableBias(false);
    tilingApi.SetBufferSpace(-1, -1, -1);

    int64_t res = tilingApi.GetTiling(tilingData);
    if (res == -1) {
        std::printf("Error: GenerateMatmulTiling failed for shape [%d, %d, %d]\n", M, N, K);
        std::fflush(stdout);
    }
    return tilingData;
}

/*------------------------------------------------------------------------------
 * Bandwidth benchmark: GM -> UB -> GM copy
 *----------------------------------------------------------------------------*/

template <uint32_t chunkElems>
__global__ __vector__ void bandwidth_perf_custom(
    __gm__ uint8_t* src, __gm__ uint8_t* dst, uint32_t totalElems, uint32_t numBlocks)
{
    AscendC::InitSocState();

    uint32_t blockIdx = AscendC::GetBlockIdx();
    uint32_t elemsPerBlock = (totalElems + numBlocks - 1) / numBlocks;
    uint32_t blockOffset = blockIdx * elemsPerBlock;
    uint32_t elementsToProcess = chunkElems;
    if (blockOffset >= totalElems) {
        elementsToProcess = 0;
    } else if (blockOffset + elementsToProcess > totalElems) {
        elementsToProcess = totalElems - blockOffset;
    }
    if (elementsToProcess > chunkElems) {
        elementsToProcess = chunkElems;
    }

    AscendC::GlobalTensor<half> srcGlobal;
    AscendC::GlobalTensor<half> dstGlobal;
    srcGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ half*>(src) + blockOffset, elementsToProcess);
    dstGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ half*>(dst) + blockOffset, elementsToProcess);

    AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAllocator;
    AscendC::LocalTensor<half> tmpLocal = ubAllocator.Alloc<half, chunkElems>();

    AscendC::DataCopy(tmpLocal, srcGlobal, elementsToProcess);
    AscendC::PipeBarrier<PIPE_ALL>();
    AscendC::DataCopy(dstGlobal, tmpLocal, elementsToProcess);
    AscendC::PipeBarrier<PIPE_ALL>();
}

/*------------------------------------------------------------------------------
 * Host-side helpers
 *----------------------------------------------------------------------------*/

static double ComputeTflops(int64_t M, int64_t N, int64_t K, double seconds)
{
    // One multiply-add = 2 floating-point operations.
    double flops = 2.0 * static_cast<double>(M) * static_cast<double>(N) * static_cast<double>(K);
    return (flops / 1e12) / seconds;
}

static double ComputeBandwidthGBs(size_t bytes, double seconds)
{
    // bytes / seconds / 1e9 = GB/s
    return static_cast<double>(bytes) / seconds / 1e9;
}

static void PrintUsage(const char* prog)
{
    std::printf("Usage:\n");
    std::printf("  %s compute M N K [warmup_iters] [measure_iters]\n", prog);
    std::printf("  %s bandwidth total_bytes [warmup_iters] [measure_iters]\n", prog);
    std::printf("\nExamples:\n");
    std::printf("  %s compute 4096 4096 4096\n", prog);
    std::printf("  %s bandwidth 67108864\n", prog);
}

static int RunComputeMode(int argc, char* argv[])
{
    if (argc < 5) {
        PrintUsage(argv[0]);
        return 1;
    }

    int32_t M = static_cast<int32_t>(std::strtol(argv[2], nullptr, 10));
    int32_t N = static_cast<int32_t>(std::strtol(argv[3], nullptr, 10));
    int32_t K = static_cast<int32_t>(std::strtol(argv[4], nullptr, 10));
    uint32_t warmup = (argc > 5) ? static_cast<uint32_t>(std::strtoul(argv[5], nullptr, 10))
                                 : WARMUP_ITER_DEFAULT;
    uint32_t iters = (argc > 6) ? static_cast<uint32_t>(std::strtoul(argv[6], nullptr, 10))
                                : MEASURE_ITER_DEFAULT;

    if (M <= 0 || N <= 0 || K <= 0) {
        std::printf("Error: M, N, K must be positive.\n");
        return 1;
    }

#if defined(ASCENDC_CPU_DEBUG) && (__NPU_ARCH__ == 2201)
    auto ascendcPlatform = platform_ascendc::PlatformAscendCManager::GetInstance("Ascend910B1");
#elif defined(ASCENDC_CPU_DEBUG) && (__NPU_ARCH__ == 3510)
    auto ascendcPlatform = platform_ascendc::PlatformAscendCManager::GetInstance("Ascend950PR_9589");
#else
    auto ascendcPlatform = platform_ascendc::PlatformAscendCManager::GetInstance();
#endif

    auto tiling = GenerateMatmulTiling(ascendcPlatform, M, N, K);
    if (tiling.usedCoreNum == 0) {
        std::printf("Error: tiling produced zero used cores.\n");
        return 1;
    }

    size_t aBytes = static_cast<size_t>(M) * K * sizeof(half);
    size_t bBytes = static_cast<size_t>(K) * N * sizeof(half);
    size_t cBytes = static_cast<size_t>(M) * N * sizeof(float);
    size_t systemWorkspaceSize = static_cast<size_t>(ascendcPlatform->GetLibApiWorkSpaceSize());

    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t* aHost = nullptr;
    uint8_t* aDevice = nullptr;
    aclrtMallocHost((void**)(&aHost), aBytes);
    aclrtMalloc((void**)&aDevice, aBytes, ACL_MEM_MALLOC_HUGE_FIRST);
    for (size_t i = 0; i < aBytes; ++i) {
        aHost[i] = static_cast<uint8_t>(i & 0xff);
    }
    aclrtMemcpy(aDevice, aBytes, aHost, aBytes, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* bHost = nullptr;
    uint8_t* bDevice = nullptr;
    aclrtMallocHost((void**)(&bHost), bBytes);
    aclrtMalloc((void**)&bDevice, bBytes, ACL_MEM_MALLOC_HUGE_FIRST);
    for (size_t i = 0; i < bBytes; ++i) {
        bHost[i] = static_cast<uint8_t>((i + 1) & 0xff);
    }
    aclrtMemcpy(bDevice, bBytes, bHost, bBytes, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* cDevice = nullptr;
    aclrtMalloc((void**)&cDevice, cBytes, ACL_MEM_MALLOC_HUGE_FIRST);

    uint8_t* workspaceDevice = nullptr;
    aclrtMalloc((void**)&workspaceDevice, systemWorkspaceSize, ACL_MEM_MALLOC_HUGE_FIRST);

    uint32_t numBlocks = tiling.usedCoreNum;

    // Warmup
    for (uint32_t i = 0; i < warmup; ++i) {
        matmul_perf_custom<<<numBlocks, nullptr, stream>>>(
            aDevice, bDevice, cDevice, workspaceDevice, tiling);
    }
    aclrtSynchronizeStream(stream);

    // Measure
    auto t0 = std::chrono::high_resolution_clock::now();
    for (uint32_t i = 0; i < iters; ++i) {
        matmul_perf_custom<<<numBlocks, nullptr, stream>>>(
            aDevice, bDevice, cDevice, workspaceDevice, tiling);
    }
    aclrtSynchronizeStream(stream);
    auto t1 = std::chrono::high_resolution_clock::now();

    double totalSeconds = std::chrono::duration<double>(t1 - t0).count();
    double avgSeconds = totalSeconds / static_cast<double>(iters);
    double tflops = ComputeTflops(M, N, K, avgSeconds);

    std::printf("\n=== Compute Benchmark (Matmul) ===\n");
    std::printf("Shape            : %d x %d x %d\n", M, N, K);
    std::printf("Used cores       : %u\n", numBlocks);
    std::printf("Warmup iters     : %u\n", warmup);
    std::printf("Measure iters    : %u\n", iters);
    std::printf("Total time       : %.3f ms\n", totalSeconds * 1e3);
    std::printf("Avg time/iter    : %.3f ms\n", avgSeconds * 1e3);
    std::printf("TFLOPS           : %.3f\n", tflops);
    std::printf("FLOPs/iter       : %.3e\n", 2.0 * M * N * K);

    aclrtFree(aDevice);
    aclrtFreeHost(aHost);
    aclrtFree(bDevice);
    aclrtFreeHost(bHost);
    aclrtFree(cDevice);
    aclrtFree(workspaceDevice);
    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return 0;
}

static int RunBandwidthMode(int argc, char* argv[])
{
    if (argc < 3) {
        PrintUsage(argv[0]);
        return 1;
    }

    size_t totalBytes = static_cast<size_t>(std::strtoull(argv[2], nullptr, 10));
    uint32_t warmup = (argc > 3) ? static_cast<uint32_t>(std::strtoul(argv[3], nullptr, 10))
                                 : WARMUP_ITER_DEFAULT;
    uint32_t iters = (argc > 4) ? static_cast<uint32_t>(std::strtoul(argv[4], nullptr, 10))
                                : MEASURE_ITER_DEFAULT;

    if (totalBytes == 0 || (totalBytes % sizeof(half)) != 0) {
        std::printf("Error: total_bytes must be a positive multiple of %zu.\n", sizeof(half));
        return 1;
    }

    uint32_t totalElems = static_cast<uint32_t>(totalBytes / sizeof(half));

    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t* srcHost = nullptr;
    uint8_t* srcDevice = nullptr;
    aclrtMallocHost((void**)(&srcHost), totalBytes);
    aclrtMalloc((void**)&srcDevice, totalBytes, ACL_MEM_MALLOC_HUGE_FIRST);
    for (size_t i = 0; i < totalBytes; ++i) {
        srcHost[i] = static_cast<uint8_t>(i & 0xff);
    }
    aclrtMemcpy(srcDevice, totalBytes, srcHost, totalBytes, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* dstDevice = nullptr;
    aclrtMalloc((void**)&dstDevice, totalBytes, ACL_MEM_MALLOC_HUGE_FIRST);

    // Use a reasonable number of blocks; cap to avoid tiny chunks.
    uint32_t numBlocks = 8;
    uint32_t minChunkBytes = 4096;
    uint32_t maxBlocksByChunk = static_cast<uint32_t>(totalBytes / minChunkBytes);
    if (maxBlocksByChunk > 0 && maxBlocksByChunk < numBlocks) {
        numBlocks = maxBlocksByChunk;
    }
    if (numBlocks < 1) {
        numBlocks = 1;
    }

    // Warmup
    for (uint32_t i = 0; i < warmup; ++i) {
        bandwidth_perf_custom<BANDWIDTH_CHUNK_SIZE><<<numBlocks, nullptr, stream>>>(
            srcDevice, dstDevice, totalElems, numBlocks);
    }
    aclrtSynchronizeStream(stream);

    // Measure
    auto t0 = std::chrono::high_resolution_clock::now();
    for (uint32_t i = 0; i < iters; ++i) {
        bandwidth_perf_custom<BANDWIDTH_CHUNK_SIZE><<<numBlocks, nullptr, stream>>>(
            srcDevice, dstDevice, totalElems, numBlocks);
    }
    aclrtSynchronizeStream(stream);
    auto t1 = std::chrono::high_resolution_clock::now();

    double totalSeconds = std::chrono::duration<double>(t1 - t0).count();
    double avgSeconds = totalSeconds / static_cast<double>(iters);
    double gbs = ComputeBandwidthGBs(totalBytes, avgSeconds);

    std::printf("\n=== Bandwidth Benchmark (GM -> UB -> GM) ===\n");
    std::printf("Total bytes      : %zu\n", totalBytes);
    std::printf("Total elements   : %u (half)\n", totalElems);
    std::printf("Blocks used      : %u\n", numBlocks);
    std::printf("Warmup iters     : %u\n", warmup);
    std::printf("Measure iters    : %u\n", iters);
    std::printf("Total time       : %.3f ms\n", totalSeconds * 1e3);
    std::printf("Avg time/iter    : %.3f ms\n", avgSeconds * 1e3);
    std::printf("Bandwidth        : %.3f GB/s\n", gbs);
    std::printf("Note: bandwidth counts bytes moved (read + write).\n");

    aclrtFree(srcDevice);
    aclrtFreeHost(srcHost);
    aclrtFree(dstDevice);
    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return 0;
}

/*------------------------------------------------------------------------------
 * Entry point
 *----------------------------------------------------------------------------*/

int32_t main(int32_t argc, char* argv[])
{
    if (argc < 2) {
        PrintUsage(argv[0]);
        return 1;
    }

    std::string mode(argv[1]);
    if (mode == "compute") {
        return RunComputeMode(argc, argv);
    }
    if (mode == "bandwidth") {
        return RunBandwidthMode(argc, argv);
    }

    std::printf("Error: unknown mode '%s'. Use 'compute' or 'bandwidth'.\n", mode.c_str());
    PrintUsage(argv[0]);
    return 1;
}
